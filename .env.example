# API Keys
# ZAI API Key (for GLM model access)
ZAI_API_KEY=your_zai_api_key_here

# OpenRouter API Key (for OpenRouter model access)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Kimi API Key (for Kimi K2.5 model access)
KIMI_API_KEY=your_kimi_api_key_here

# LiteLLM Master Key (for proxy administration)
# Generate a secure key: openssl rand -hex 32
LITELLM_MASTER_KEY=your_lite_llm_master_key_here

# Database URL (for Docker - uses service name)
DATABASE_URL=postgresql://litellm_user:litellm_password@postgres:5432/litellm
